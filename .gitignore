# Cache and logs (Symfony2)
.agent
.geminiignore
/app/cache/*
/app/crypto_dir/*
/app/crypto_dir
/app/amcsd_files
/app/logs/*
/app/tmp/*
!app/cache/.gitkeep
!app/logs/.gitkeep

# Cache and logs (Symfony3)
/var/cache/*
/var/logs/*
!var/cache/.gitkeep
!var/logs/.gitkeep

# Cache and logs (Symfony4)
/var/log/*

# Parameters
/app/config/config.yml
/app/config/parameters.yml
/app/config/parameters.ini
/app/config/security.yml
/app/config/jwt/*

# Managed by Composer
/app/bootstrap.php.cache
/var/bootstrap.php.cache
/bin/*
!bin/console
!bin/symfony_requirements
/vendor/

# Assets and user uploads
/web/bundles/
/web/uploads/
/web/uploads
/web/node_modules/
/web/chemin-map-demo/
/web/zipped_data_files
/web/AMS
/web/log_view_config.php

# Claude
.claude/
CLAUDE.md
CLAUDE_LOG.md

# PHPUnit
/app/phpunit.xml
/phpunit.xml
/test-browser/node_modules/
/test-browser/screenshots/*
!/test-browser/screenshots/.gitkeep 
/test-browser/conf/*.conf.js

# Composer PHAR
/composer.phar

# Dev tools
.idea/

# Do not track Chemin Map Demo
web/chemin-map-demo


/background_services/node_modules/
/background_services/statistics_config.js
/background_services/.env
/puppeteer_graphs/node_modules/

# Node.js
node_modules/

# Playwright
tests/screenshots/test-results/
tests/screenshots/snapshots/
tests/screenshots/.auth/

# Rector tool binary (config rector.php is tracked)
rector.phar

# HOM URL resolver output (background_services/hom_url_checker.js)
/background_services/hom_results
