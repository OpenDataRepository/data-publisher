# Static-render daemon configuration. Copy this file to `.env` in the
# same directory and fill in real values. `.env` is gitignored.

# Public-API credentials used by static_render_daemon.js to fetch the
# JSON representation of each rendered record. The account must:
#   - Be permitted to authenticate via /api/v5/token (JSON login).
#   - Have read access to whichever records you want JSON snapshots of.
#     A user with public-only access is sufficient because the static
#     cache is for public consumption anyway.
#
# If either value is empty (or missing entirely) the daemon still renders
# HTML normally, just without the .json companion file.
ODR_API_USERNAME=
ODR_API_PASSWORD=

# Optional. Set to "1" to disable JSON fetching entirely without
# clearing the credentials above. Useful for local dev runs where you
# don't need the JSON snapshots.
# STATIC_RENDER_SKIP_JSON=0

# Optional toggles (already supported by the daemon, listed here so the
# operator sees them all in one place):
#
# Number of parallel render slots. Default 1; capped at 16. Each slot
# opens its own beanstalkd connection and Puppeteer page; they share
# the single browser.
# STATIC_RENDER_CONCURRENCY=1
#
# Force a specific Chromium binary. Otherwise the daemon probes
# common paths (Playwright cache, system chromium, etc.).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
#
# Skip HTTPS certificate validation when the target host uses a
# self-signed cert. DEV ONLY.
# STATIC_RENDER_IGNORE_HTTPS_ERRORS=1
